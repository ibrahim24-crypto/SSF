rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPER FUNCTIONS
    ==========================*/

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return isSignedIn() && exists(userDocPath());
    }

    function getUserData() {
      return userDocExists()
        ? get(userDocPath()).data
        : {};
    }

    function isSuperAdmin() {
      return isSignedIn() &&
             request.auth.token.email == "ibrahimezzine09@gmail.com";
    }

    function isAdmin() {
      return userDocExists() &&
             getUserData().role == "admin";
    }

    function hasPermission(permission) {
      return isAdmin() &&
             permission in getUserData().permissions &&
             getUserData().permissions[permission] == true;
    }

    /* =========================
       USERS COLLECTION
    ==========================*/

    match /users/{userId} {

      // User can read their own doc
      allow read: if isOwner(userId) || isAdmin();

      allow list: if isAdmin();

      // First login safe creation
      allow create: if isOwner(userId)
                    && request.resource.data.uid == request.auth.uid;

      // Super admin OR admin with permission
      allow update: if isSuperAdmin()
                    || (isAdmin() && hasPermission("manage_admins"));

      allow delete: if (isSuperAdmin()
                        || (isAdmin() && hasPermission("delete_users")))
                        && request.auth.uid != userId;
    }

    /* =========================
       DISPLAY NAMES
    ==========================*/

    match /userDisplayNames/{name} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
    }

    /* =========================
       POSTS
    ==========================*/

    match /posts/{postId} {

      // Public can read approved posts
      allow read: if resource.data.status == "approved"
                  || isAdmin()
                  || isOwner(resource.data.authorUid);

      allow create: if isSignedIn();

      allow update: if

        // Voting only
        (isSignedIn()
         && resource.data.status == "approved"
         && request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(["upvotes", "downvotes", "commentCount"]))

        ||

        // Admin moderation
        (isAdmin()
         && hasPermission("approve_pictures")
         && request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasAny(["status", "images", "hasPendingImages", "updatedAt"]))

        ||

        // Author editing own post
        (isOwner(resource.data.authorUid)
         && request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(["title", "content", "category", "eventDate",
                        "customFields", "images", "hasPendingImages",
                        "updatedAt", "isFlagged"]))

        ||

        isSuperAdmin();

      allow delete: if isOwner(resource.data.authorUid)
                    || isSuperAdmin()
                    || (isAdmin() && hasPermission("delete_posts"));
    }

    /* =========================
       VOTES
    ==========================*/

    match /votes/{voteId} {
      allow read: if isOwner(resource.data.userId);
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    /* =========================
       COMMENTS
    ==========================*/

    match /comments/{commentId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.content != null
                    && request.resource.data.content.size() > 0
                    && request.resource.data.content.size() < 500;

      allow delete: if isOwner(resource.data.userId)
                    || isSuperAdmin()
                    || (isAdmin() && hasPermission("delete_comments"));
    }

    /* =========================
       SETTINGS
    ==========================*/

    match /settings/{document} {

      allow read: if isSignedIn();

      allow write: if isSuperAdmin()
        || (isAdmin() &&
            (
              (document == "config" &&
               hasPermission("manage_forbidden_words"))
              ||
              (document == "protectedNames" &&
               hasPermission("manage_protected_names"))
            ));
    }
  }
}